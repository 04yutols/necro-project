generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth.js v5 必須モデル ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── コアモデル ────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  displayName   String?
  passwordHash  String?   // ID/PW 認証用（bcrypt ハッシュ）
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  characters    Character[]
  ownedItems    Item[]  @relation("ItemOwner")
  discoveredItems Item[]  @relation("Discoverer")
  stageRecords  StageRecord[]
  playerStats   PlayerStats?
  worldLogs     WorldLog[]
}

model Character {
  id              String   @id @default(uuid())
  name            String
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])

  // 資産・オンライン同期
  gold            Int      @default(50000)

  // 8種の基礎ステータス（HSR互換）
  hp              Int
  atk             Int
  def             Int
  spd             Int
  critRate        Float    @default(5.0)
  critDmg         Float    @default(150.0)
  effectHit       Float    @default(0.0)
  effectRes       Float    @default(0.0)

  // 職業レベル到達時に獲得する永続パッシブの累積補正
  passiveAtkBonus      Int    @default(0)
  passiveDefBonus      Int    @default(0)
  passiveSpdBonus      Int    @default(0)
  passiveCritRateBonus Float  @default(0)
  passiveCritDmgBonus  Float  @default(0)
  passiveHpBonus       Int    @default(0)

  // 職業システム
  jobs            UserJob[]
  currentJobId    String?

  // 8枠装備スロット
  equipWeaponId   String?
  equipSubId      String?
  equipHeadId     String?
  equipBodyId     String?
  equipArmsId     String?
  equipLegsId     String?
  equipAcc1Id     String?
  equipAcc2Id     String?

  equipWeapon     Item?    @relation("Weapon", fields: [equipWeaponId], references: [id])
  equipSub        Item?    @relation("Sub",    fields: [equipSubId],    references: [id])
  equipHead       Item?    @relation("Head",   fields: [equipHeadId],   references: [id])
  equipBody       Item?    @relation("Body",   fields: [equipBodyId],   references: [id])
  equipArms       Item?    @relation("Arms",   fields: [equipArmsId],   references: [id])
  equipLegs       Item?    @relation("Legs",   fields: [equipLegsId],   references: [id])
  equipAcc1       Item?    @relation("Acc1",   fields: [equipAcc1Id],   references: [id])
  equipAcc2       Item?    @relation("Acc2",   fields: [equipAcc2Id],   references: [id])

  // 死霊術ステータス
  necroLevel      Int      @default(1)
  necroRank       Int      @default(1)
  necroExp        Int      @default(0)
  necroMaxCost    Int      @default(10)
  necroBaseStatsBonus Float @default(1.0)

  // パーティ編成（3枠）
  partySlot0Id    String?
  partySlot1Id    String?
  partySlot2Id    String?
  partySlot0      Monster? @relation("PartySlot0", fields: [partySlot0Id], references: [id], onDelete: SetNull)
  partySlot1      Monster? @relation("PartySlot1", fields: [partySlot1Id], references: [id], onDelete: SetNull)
  partySlot2      Monster? @relation("PartySlot2", fields: [partySlot2Id], references: [id], onDelete: SetNull)
  inventoryMonsters Monster[] @relation("CharacterMonsters")

  // 進行管理
  clearedStages   String[] @default([])

  // 深淵の残滓（5部位）
  abyssalResidues AbyssalResidue[] @relation("CharacterResidues")
  equippedResidue0Id String?
  equippedResidue1Id String?
  equippedResidue2Id String?
  equippedResidue3Id String?
  equippedResidue4Id String?
  equippedResidue0   AbyssalResidue? @relation("ResidueSlot0", fields: [equippedResidue0Id], references: [id], onDelete: SetNull)
  equippedResidue1   AbyssalResidue? @relation("ResidueSlot1", fields: [equippedResidue1Id], references: [id], onDelete: SetNull)
  equippedResidue2   AbyssalResidue? @relation("ResidueSlot2", fields: [equippedResidue2Id], references: [id], onDelete: SetNull)
  equippedResidue3   AbyssalResidue? @relation("ResidueSlot3", fields: [equippedResidue3Id], references: [id], onDelete: SetNull)
  equippedResidue4   AbyssalResidue? @relation("ResidueSlot4", fields: [equippedResidue4Id], references: [id], onDelete: SetNull)
}

model Job {
  id       String    @id
  name     String
  tier     Int
  category String    // PHYSICAL | MAGICAL
  userJobs UserJob[]
}

model UserJob {
  characterId String
  jobId       String
  level       Int       @default(1)
  exp         Int       @default(0)
  character   Character @relation(fields: [characterId], references: [id])
  job         Job       @relation(fields: [jobId],       references: [id])

  @@id([characterId, jobId])
}

model Item {
  id            String   @id @default(uuid())
  name          String
  type          String   // WEAPON | HEAD | BODY ...
  rarity        String   // R | SR | SSR | UR | COMMON | RARE | EPIC

  // 基本ステータス補正
  atk           Int      @default(0)
  def           Int      @default(0)
  critRate      Float    @default(0.0)
  critDmg       Float    @default(0.0)
  spd           Int      @default(0)
  specialEffect String?

  // 武器システム（§13 武器システム.md）
  rank          Int      @default(0)    // 魂の共鳴 0-5
  archetype     String?                 // LOW | MID | HIGH | MYTHIC
  ilv           Int?                    // アイテムレベル 1-90
  passiveA      Json?                   // WeaponPassive { nameJa, descTemplate, values[], systemTag? }
  passiveB      Json?                   // WeaponPassive { nameJa, descTemplate, values[], systemTag? }

  // ランダムオプション
  subOptions    Json?    // Array of { type: string, value: number }

  // 第一発見者システム
  ownerId       String?
  owner         User?    @relation("ItemOwner", fields: [ownerId], references: [id])
  isUnique      Boolean  @default(false)
  discovererId  String?
  discovererName String?
  discoverer    User?    @relation("Discoverer", fields: [discovererId], references: [id])
  serialNo      Int?
  discoveredAt  DateTime?

  // 装備リレーション（Character の各スロットから参照）
  equippedWeapon  Character[] @relation("Weapon")
  equippedSub     Character[] @relation("Sub")
  equippedHead    Character[] @relation("Head")
  equippedBody    Character[] @relation("Body")
  equippedArms    Character[] @relation("Arms")
  equippedLegs    Character[] @relation("Legs")
  equippedAcc1    Character[] @relation("Acc1")
  equippedAcc2    Character[] @relation("Acc2")
}

model ItemSerialCounter {
  itemName String @id
  counter  Int    @default(0)
}

model AbyssalResidue {
  id          String    @id @default(uuid())
  name        String
  // itemId は装備スロット種別 ('head'|'arms'|'chest'|'waist'|'legs') — Item FK ではない
  itemId      String
  characterId String?
  character   Character? @relation("CharacterResidues", fields: [characterId], references: [id], onDelete: SetNull)
  equippedResidue0Of Character[] @relation("ResidueSlot0")
  equippedResidue1Of Character[] @relation("ResidueSlot1")
  equippedResidue2Of Character[] @relation("ResidueSlot2")
  equippedResidue3Of Character[] @relation("ResidueSlot3")
  equippedResidue4Of Character[] @relation("ResidueSlot4")

  rarity      String   @default("COMMON")  // COMMON | RARE | EPIC | LEGENDARY
  mainStat    Json                          // { type: string, value: number }
  subOptions  Json     @default("[]")       // Array of { type: string, value: number }
  level       Int      @default(1)
  exp         Int      @default(0)
  maxExp      Int      @default(800)
}

model Monster {
  id          String  @id @default(uuid())
  masterId    String?
  characterId String?
  character   Character? @relation("CharacterMonsters", fields: [characterId], references: [id], onDelete: SetNull)
  name        String
  tribe       String
  cost        Int
  hp          Int
  atk         Int
  def         Int
  spd         Int
  critRate    Float   @default(0.0)
  critDmg     Float   @default(150.0)
  effectHit   Float   @default(0.0)
  effectRes   Float   @default(0.0)
  resistances  Json    @default("{}")

  soulShardId  String?
  soulShard    SoulShard?  @relation(fields: [soulShardId],  references: [id])
  spiritCoreId String?
  spiritCore   SpiritCore? @relation(fields: [spiritCoreId], references: [id])
  partySlot0Of Character[] @relation("PartySlot0")
  partySlot1Of Character[] @relation("PartySlot1")
  partySlot2Of Character[] @relation("PartySlot2")
}

model SoulShard {
  id              String    @id @default(uuid())
  originMonster   String
  atkBonus        Int       @default(0)
  elementDmgBoost Int       @default(0)
  specialAbility  String?
  monsters        Monster[]
}

model SpiritCore {
  id            String    @id @default(uuid())
  name          String
  element       String?
  skillChangeId String?
  atkMultiplier Float     @default(1.0)
  monsters      Monster[]
}

model StageRecord {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageId        String
  turnCount      Int
  clearTimeSec   Int      @default(0)
  totalDamage    Int      @default(0)
  clearedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, stageId])
  @@index([stageId, turnCount])
  @@index([stageId, clearTimeSec])
}

model PlayerStats {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalDamage      BigInt   @default(0)
  bossKillCount    Int      @default(0)
  bestResidueScore Float    @default(0)
  updatedAt        DateTime @updatedAt
}

model WorldLog {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type, createdAt])
}
