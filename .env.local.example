# ─── このファイルを .env.local にコピーして値を記入する ───────────────────────
# cp .env.local.example .env.local

# ─── NextAuth ────────────────────────────────────────────────────────────────
# openssl rand -base64 32 で生成
AUTH_SECRET=""

# ─── Neon PostgreSQL ─────────────────────────────────────────────────────────
# Neon ダッシュボード → プロジェクト → Connection string から取得
# 必ず ?sslmode=require を含める
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
